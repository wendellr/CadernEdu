# CadernEdu — Variáveis de ambiente para Portainer (produção)
#
# Como usar:
#   Portainer → Stack → "Load variables from .env file" → selecionar este arquivo
#   Preencha cada valor antes de fazer o deploy.
#
# NUNCA commite este arquivo com valores reais.

# ── Domínio público ───────────────────────────────────────────────────────────
# Base do domínio (ex: cadernedu.ioda.com.br)
# Subdomínios: api.DOMAIN e painel.DOMAIN são configurados pelo script Nginx
DOMAIN=cadernedu.ioda.com.br

# ── GitHub Container Registry ────────────────────────────────────────────────
# Seu usuário ou org no GitHub
GITHUB_OWNER=seu-usuario-github

# Tag das imagens — "latest" ou SHA específico (ex: a1b2c3d4)
IMAGE_TAG=latest

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=cadernedu
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=cadernedu_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ACCESS_KEY=cadernedu
MINIO_SECRET_KEY=TROQUE_POR_SENHA_FORTE_MIN_8_CHARS
MINIO_BUCKET=cadernedu-prod

# ── API / JWT ─────────────────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
SECRET_KEY=GERE_COM_openssl_rand_hex_32

# ── Keycloak (futuro — por enquanto deixar o padrão) ─────────────────────────
KEYCLOAK_REALM=cadernedu
KEYCLOAK_CLIENT_ID=cadernedu-api
