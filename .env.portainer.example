# CadernEdu — Variáveis de ambiente para Portainer (staging/produção)
#
# Como usar:
#   Portainer → Stack → "Load variables from .env file" → selecionar este arquivo
#   Preencha cada valor antes de fazer o deploy.
#
# NUNCA commite este arquivo com valores reais.

# ── Domínio público ───────────────────────────────────────────────────────────
# Base do domínio (ex: cadernedu.ioda.com.br)
# Subdomínios: api.DOMAIN e painel.DOMAIN são configurados pelo script Nginx
DOMAIN=cadernedu.ioda.com.br

# O compose do Portainer faz build local a partir do repositório Git.
# Não há registry externo nem Traefik nesta stack; o proxy reverso é Nginx.

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=cadernedu
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=cadernedu_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ACCESS_KEY=cadernedu
MINIO_SECRET_KEY=TROQUE_POR_SENHA_FORTE_MIN_8_CHARS
MINIO_BUCKET=cadernedu-prod

# ── Ambiente ──────────────────────────────────────────────────────────────────
# "staging" = login dev habilitado, Swagger visível (piloto sem Keycloak)
# "production" = login dev bloqueado, requer Keycloak
ENVIRONMENT=staging

# Para rodar o seed demo pelo serviço opcional `seed_demo`, habilite
# temporariamente este profile no Portainer, faça o deploy, aguarde o
# container cadernedu-seed-demo concluir e depois remova a variável.
# ATENÇÃO: o seed demo usa --reset e apaga/recria os dados da stack.
# COMPOSE_PROFILES=demo-seed

# ── API / JWT ─────────────────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
SECRET_KEY=GERE_COM_openssl_rand_hex_32

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula (sem espaços)
CORS_ORIGINS=https://cadernedu.ioda.com.br,https://painel.cadernedu.ioda.com.br

# ── Keycloak (futuro — por enquanto deixar o padrão) ─────────────────────────
KEYCLOAK_REALM=cadernedu
KEYCLOAK_CLIENT_ID=cadernedu-api
