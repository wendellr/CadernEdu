# Copie para .env na raiz do monorepo.
# O arquivo .env NUNCA deve ser commitado.
#
# Docker Compose lê este arquivo automaticamente ao rodar da raiz.
# COMPOSE_FILE define quais arquivos são carregados e em que ordem.

# ── Docker Compose ────────────────────────────────────────────────────────────
COMPOSE_FILE=infra/docker-compose.yml:infra/docker-compose.override.yml

# Para CI, substitua por:
# COMPOSE_FILE=infra/docker-compose.yml:infra/docker-compose.ci.yml

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=cadernedu
POSTGRES_PASSWORD=dev
POSTGRES_DB=cadernedu_dev

# ── Storage (MinIO) ───────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=cadernedu
MINIO_SECRET_KEY=dev_secret_change_me
MINIO_BUCKET=cadernedu-dev
MINIO_SECURE=false

# ── API ───────────────────────────────────────────────────────────────────────
# Obrigatório. Gere com: openssl rand -hex 32
SECRET_KEY=

ENVIRONMENT=development
DEBUG=true
IMAGE_TAG=local

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_REALM=cadernedu
KEYCLOAK_CLIENT_ID=cadernedu-api
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Serviços externos (staging / prod) ────────────────────────────────────────
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
GOVBR_REDIRECT_URI=
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
ANTHROPIC_API_KEY=
SENTRY_DSN=
