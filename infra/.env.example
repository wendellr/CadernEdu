# Copie para .env e preencha os valores antes de subir a stack.
# O arquivo .env NUNCA deve ser commitado.

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=cadernedu
POSTGRES_PASSWORD=dev
POSTGRES_DB=cadernedu_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
# (sem senha em dev — adicionar requirepass em prod)

# ── MinIO / Storage ───────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=cadernedu
MINIO_SECRET_KEY=dev_secret_change_me
MINIO_BUCKET=cadernedu-dev
MINIO_SECURE=false

# ── API ───────────────────────────────────────────────────────────────────────
# Obrigatório — mínimo 32 caracteres. Gere com: openssl rand -hex 32
SECRET_KEY=

ENVIRONMENT=development
DEBUG=true

# Tag da imagem Docker usada em prod/staging (ex: v1.2.3, git sha, latest)
IMAGE_TAG=local

# ── Keycloak (profile: full) ──────────────────────────────────────────────────
KEYCLOAK_REALM=cadernedu
KEYCLOAK_CLIENT_ID=cadernedu-api
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
